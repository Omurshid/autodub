{
  "manifest_version": 3,
  "name": "DubIt - AI Video Dubber",
  "version": "0.1.0",
  "description": "Dub any video into English while preserving the original speaker's voice",
  "permissions": [
    "activeTab",
    "storage",
    "tabCapture",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "DubIt - Click to toggle dubbing"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
